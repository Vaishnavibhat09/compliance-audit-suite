# HTTP server port
PORT=4000

# SQLite database file (created automatically on first boot)
DATABASE_PATH=./storage/audit-suite.db

# Where uploaded PDFs, screenshots, reports and zip bundles are written
STORAGE_ROOT=./storage

# Default target application + credentials used to pre-fill the audit form.
# These can always be overridden per-audit from the web UI.
DEFAULT_TARGET_URL=https://white-cliff-0bca3ed00.1.azurestaticapps.net
DEFAULT_LOGIN_EMAIL=admin@gmail.com
DEFAULT_LOGIN_PASSWORD=password

# Run the inspection browser without a visible window (recommended on servers)
HEADLESS_BROWSER=true

# Default LLM adjudication provider: groq | openai | gemini
DEFAULT_AI_PROVIDER=groq
DEFAULT_AI_MODEL=llama-3.3-70b-versatile

# Optional: pre-fill server-side API keys so the UI field can be left blank.
# Never commit real secrets into this file.
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
