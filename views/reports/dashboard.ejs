<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Compliance Dashboard</title>
<style>
  body { margin: 0; font-family: "Segoe UI", Roboto, system-ui, sans-serif; background: #10131a; color: #e7e9ee; padding: 32px; }
  .sheet { max-width: 960px; margin: 0 auto; background: white; color: #1b1f27; border-radius: 16px; overflow: hidden; box-shadow: 0 24px 60px rgba(0,0,0,.45); }
  .banner { background: linear-gradient(135deg,#4f46e5,#0d0f14); color: white; padding: 36px 40px; text-align: center; }
  .banner h1 { margin: 0 0 6px; }
  .banner .score { font-size: 54px; font-weight: 700; margin-top: 12px; }
  .body { padding: 32px 40px; }
  table { width: 100%; border-collapse: collapse; }
  th { background: #1b1f27; color: white; padding: 12px; text-align: left; }
  td { padding: 12px; border-bottom: 1px solid #ececec; }
  tr:nth-child(even) td { background: #fafafa; }
  .pill { padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; }
  .pill.PASS { background: #dcfce7; color: #15803d; }
  .pill.WARNING { background: #fef3c7; color: #b45309; }
  .pill.FAIL { background: #fee2e2; color: #b91c1c; }
  footer { text-align: center; padding: 24px; color: #6b7280; font-size: 13px; }
</style>
</head>
<body>
  <div class="sheet">
    <div class="banner">
      <h1>Compliance Audit Dashboard</h1>
      <div>Target: <%= targetUrl %></div>
      <div class="score"><%= overallScore %>%</div>
    </div>
    <div class="body">
      <table>
        <tr><th>Screen</th><th>Score</th><th>Status</th></tr>
        <% pages.forEach(function(page) { %>
        <tr>
          <td><%= page.pageTitle %></td>
          <td><%= page.complianceScore %>%</td>
          <td><span class="pill <%= page.status %>"><%= page.status %></span></td>
        </tr>
        <% }) %>
      </table>
    </div>
    <footer>Generated by Compliance Audit Suite on <%= generatedAt %></footer>
  </div>
</body>
</html>
